[global]
    ### Display ###
    monitor = 0
    follow = mouse
    
    # Size and Position
    width = 350
    height = 110
    origin = top-right
    offset = 20x20
    
    # Appearance
    # (Rendered in 10-point Sans by default)
    font = JetBrains Mono 10
    corner_radius = 10
    frame_width = 1
    frame_color = "#89b4fa80"
    separator_color = frame
    
    # Spacing
    padding = 15
    horizontal_padding = 15
    text_icon_padding = 10
    
    # Progress Bar (for volume/brightness)
    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_corner_radius = 5

[urgency_low]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    timeout = 5

[urgency_normal]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    timeout = 10

[urgency_critical]
    background = "#1e1e2e"
    foreground = "#f38ba8"
    frame_color = "#f38ba8"
    timeout = 0
